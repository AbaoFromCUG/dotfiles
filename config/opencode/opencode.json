{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "plan",
  "provider": {
    "deepseek": {
      "models": {
        "deepseek-v4-flash": {
          "variants": {
            "thinking": {
              "thinking": {
                "type": "enabled"
              },
            },
            "nothinking": {
              "thinking": {
                "type": "disabled"
              },
            },
          }
        },
        "deepseek-v4-pro": {
          "variants": {
            "thinking": {
              "thinking": {
                "type": "enabled"
              },
            },
            "nothinking": {
              "thinking": {
                "type": "disabled"
              },
            },
          },
        },
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://mac2.local:1234/v1"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "ls": "allow",
      "find": "allow",
      "fd": "allow",
      "rg": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      "mise tasks*": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "edit": {
      "*": "ask",
      "*.md": "allow",
      "*.env*": "deny",
      "*.env.example": "ask"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "external_directory": {
      "~/Documents/github/**": "allow",
      "~/Documents/demo/**": "allow",
    },
    "doom_loop": "ask"
  },
  "instructions": [
    "AGENTS.md"
  ],
}
