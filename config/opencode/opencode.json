{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "formatter": false,
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://mac2.local:1234/v1"
      },
      "models": {
        "qwen/qwen3.6-27b": {
          "name": "Qwen3.6 27b"
        },
        "qwen/qwen3.6-35b-a3b": {
          "name": "Qwen3.6 35b"
        },
        "minimax/minimax-m2.7": {
          "name": "Minmax-m2.7"
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      "mise tasks*": "allow",
      "mise run --dry-run*": "allow",
      "ls *": "allow",
      "systemctl --user status*": "allow",
      "rm *": "ask",
      "sudo *": "deny"
    },
    "glob *": "allow",
    "Glob *": "allow",
    "grep *": "allow",
    "Grep *": "allow",
    "edit": {
      "*": "ask",
      "*.md": "allow",
      "*.env*": "deny",
      "*.env.example": "ask"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "external_directory": {
      "~/Documents/github/**": "allow",
      "~/Documents/demo/**": "allow",
    },
    "doom_loop": "ask"
  },
  "instructions": [
    "AGENTS.md"
  ],
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
}
