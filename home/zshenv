typeset -U PATH
export PATH="$HOME/.local/bin:$PATH"
export EDITOR=nvim

if uname | grep -qi Darwin; then
	eval "$(/opt/homebrew/bin/brew shellenv)"
fi

### Addition config

if (($+commands[go])); then
	PATH="$PATH:$HOME/go/bin"
fi

if (($+commands[cargo])); then
	PATH="$PATH:$HOME/.cargo/bin"
fi

PATH="$PATH:/home/abao/.cache/.bun/bin"

if (($+commands[pnpm])); then
	# pnpm
	export PNPM_HOME="/home/abao/.local/share/pnpm"
	case ":$PATH:" in
	*":$PNPM_HOME/bin:"*) ;;
	*) export PATH="$PNPM_HOME/bin:$PATH" ;;
	esac
# pnpm end
fi

export bwBindPar=$HOME/Downloads/

export NLTK_DATA=$HOME/Documents/nltk_data

export HF_ENDPOINT=https://hf-mirror.com

# Platform detection for mise environments
if [ -z "$MISE_ENV" ] && [ -f /etc/os-release ]; then
    . /etc/os-release
    export MISE_ENV=$ID
fi

### Local config
[[ ! -f ~/.zshenv.local ]] || source ~/.zshenv.local
